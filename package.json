{
  "name": "hotel-ai-system",
  "version": "1.0.0",
  "description": "Hotel AI Management System with Google Gemini",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "api": "ts-node src/api/app.ts",
    "cli": "ts-node src/cli/cli.ts",
    "telegram": "ts-node src/services/telegram.service.ts",
    "build": "NODE_OPTIONS=--max-old-space-size=2048 tsc",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "seed": "ts-node src/database/seeders.ts",
    "search:files": "ts-node src/tools/search-files.ts",
    "organize:files": "ts-node src/tools/organize-files.ts",
    "preview:data": "ts-node src/tools/preview-data.ts",
    "report:generate": "ts-node src/tools/generate-report.ts",
    "migrate:data": "ts-node src/tools/migrate-data.ts",
    "type-check": "NODE_OPTIONS=--max-old-space-size=2048 tsc --noEmit",
    "mcp": "ts-node src/mcp/server.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.4.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "inquirer": "^8.2.5",
    "json2csv": "^6.0.0-alpha.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.0",
    "node-telegram-bot-api": "^0.67.0",
    "pdfkit": "^0.14.0",
    "sharp": "^0.33.0",
    "sqlite3": "^6.0.1",
    "tesseract.js": "^5.1.1",
    "uuid": "^13.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/pdfkit": "^0.13.0",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
